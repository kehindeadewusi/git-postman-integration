	"event": [
		{
			"listen": "prerequest",
			"script": {
				"type": "text/javascript",
				"exec": [
					"pm.variables.set(\"date\", new Date().toUTCString());",
					"pm.request.body ? pm.variables.set(\"content_length\",pm.request.body.toString().length):\"\";",
					"",
					"const canonicalResource = \"/\"+pm.variables.get(\"AccountName\") + pm.request.url.getPath();",
					"console.log (\"canonicalResource = \" + canonicalResource);",
					"",
					"// var finalstring = canonicalResource.toString().replace(/'/g,\"%27\"); Not Needed anymore",
					"var finalstring = canonicalResource;",
					"console.log (\"finalstring = \" + finalstring);",
					"",
					"const signatureRaw = new Date().toUTCString()+\"\\n\"+finalstring;",
					"console.log (\"signatureRaw = \" + signatureRaw);",
					"",
					"const storageKey = CryptoJS.enc.Base64.parse(pm.variables.get(\"PrimaryKey\"));",
					"",
					"const signatureBytes = CryptoJS.HmacSHA256(signatureRaw,storageKey);",
					"",
					"const signatureEncoded = CryptoJS.enc.Base64.stringify(signatureBytes);",
					"",
					"pm.variables.set(\"auth\", `SharedKeyLite ${pm.variables.get(\"AccountName\")}:${signatureEncoded}`);",
					""
				]
			}
		},
		{
			"listen": "test",
			"script": {
				"type": "text/javascript",
				"exec": [
					"postman.clearEnvironmentVariable(\"date\");",
					"postman.clearEnvironmentVariable(\"auth\");",
					"postman.clearEnvironmentVariable(\"content_length\");"
				]
			}
		}
